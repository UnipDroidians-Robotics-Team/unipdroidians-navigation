<?xml version="1.0"?>
<robot name="udh1" xmlns:xacro="http://ros.org/wiki/xacro">

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.0825" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.1375" rpy="0 0 0"/>
      <geometry><box size="0.62 0.41 0.275"/></geometry>
      <material name="acrilico_preto"><color rgba="0.1 0.1 0.1 0.95"/></material>
    </visual>
    <visual>
      <origin xyz="-0.02 0 0.278" rpy="0 0 0"/>
      <geometry><box size="0.52 0.38 0.006"/></geometry>
      <material name="mdf_madeira"><color rgba="0.76 0.60 0.42 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1375" rpy="0 0 0"/>
      <geometry><box size="0.62 0.41 0.275"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.1375" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1016" ixy="0.0" ixz="0.0"
               iyy="0.1917" iyz="0.0"
               izz="0.2302"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.145 0.125 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.0825" length="0.045"/></geometry>
      <material name="pneu_borracha"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0825" length="0.045"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000561" ixy="0.0" ixz="0.0"
               iyy="0.000561" iyz="0.0"
               izz="0.001021"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.145 -0.125 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.0825" length="0.045"/></geometry>
      <material name="pneu_borracha"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0825" length="0.045"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000561" ixy="0.0" ixz="0.0"
               iyy="0.000561" iyz="0.0"
               izz="0.001021"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.25 0 -0.0444" rpy="0 0 0"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.0381"/></geometry>
      <material name="pneu_borracha"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.0381"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0000581" ixy="0.0" ixz="0.0"
               iyy="0.0000581" iyz="0.0"
               izz="0.0000581"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.30 0 0.315" rpy="0 0 3.14159"/>
  </joint>

  <link name="laser_frame">
    <visual>
      <origin xyz="0 0 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.02"/></geometry>
      <material name="lidar_base"><color rgba="0.2 0.2 0.2 1.0"/></material>
    </visual>
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.02"/></geometry>
      <material name="lidar_top"><color rgba="0.05 0.05 0.05 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.05 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.000100" ixy="0.0" ixz="0.0"
               iyy="0.000100" iyz="0.0"
               izz="0.000100"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.26 0 0.48" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.124 0.029"/></geometry>
      <material name="realsense_prata"><color rgba="0.8 0.8 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.025 0.124 0.029"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000050" ixy="0.0" ixz="0.0"
               iyy="0.000050" iyz="0.0"
               izz="0.000050"/>
    </inertial>
  </link>

  <link name="notebook_base_link">
    <visual>
      <geometry><box size="0.25 0.35 0.02"/></geometry>
      <material name="notebook_gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.25 0.35 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.5"/>
      <inertia ixx="0.01536" ixy="0.0" ixz="0.0"
               iyy="0.00786" iyz="0.0"
               izz="0.02313"/>
    </inertial>
  </link>

  <joint name="notebook_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="notebook_base_link"/>
    <origin xyz="-0.05 0.0 0.29" rpy="0 0 3.14159"/>
  </joint>

  <link name="notebook_screen_link">
    <visual>
      <geometry><box size="0.02 0.35 0.25"/></geometry>
      <material name="screen_black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.35 0.25"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.00771" ixy="0.0" ixz="0.0"
               iyy="0.00262" iyz="0.0"
               izz="0.00512"/>
    </inertial>
  </link>

  <joint name="notebook_screen_joint" type="fixed">
    <parent link="notebook_base_link"/>
    <child link="notebook_screen_link"/>
    <origin xyz="-0.115 0.0 0.135" rpy="0 -0.1 0"/>
  </joint>

  <!-- Gazebo: apenas materiais, atrito e plugins (sem redeclarar links) -->
  <xacro:include filename="$(find udh1_description)/urdf/udh1.gazebo.xacro"/>

</robot>
